{{ 'section-item-marquee.css' | asset_url | stylesheet_tag }}

<div class="item-marquee" style="--bg:{{ section.settings.bg_color }};--text:{{ section.settings.text_color }};--speed:{{ section.settings.scroll_speed }}s;--gap:{{ section.settings.image_gap }}px;--row-height:{{ section.settings.row_height }}px;--image-height:{{ section.settings.image_height }}px;--margin-top:{{ section.settings.margin_top }}px;--margin-bottom:{{ section.settings.margin_bottom }}px;">

  {%- if section.settings.heading != blank -%}
    <div class="item-marquee__heading-wrapper">
      <h2 class="item-marquee__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="item-marquee__row" aria-label="Items marquee">
      <div class="item-marquee__track item-marquee__track--{{ section.settings.direction }}">
        {%- for i in (1..3) -%}
          <div class="item-marquee__group"{% if i > 1 %} aria-hidden="true"{% endif %}>
            {%- for block in section.blocks -%}
              <div class="item-marquee__item" {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank -%}
                  {%- assign img_aspect = block.settings.image.aspect_ratio -%}
                  {%- assign display_height = section.settings.image_height -%}
                  {%- assign display_width = display_height | times: img_aspect | round -%}
                  <img src="{{ block.settings.image | image_url: width: 300 }}" srcset="{{ block.settings.image | image_url: width: 150 }} 150w, {{ block.settings.image | image_url: width: 300 }} 300w, {{ block.settings.image | image_url: width: 600 }} 600w" sizes="{{ display_width }}px" alt="{{ block.settings.item_name | escape }}" decoding="async" width="{{ display_width }}" height="{{ display_height }}" class="item-marquee__image">
                {%- else -%}
                  <span class="item-marquee__name">{{ block.settings.item_name }}</span>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</div>

<script src="{{ 'section-item-marquee.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Item marquee",
  "tag": "section",
  "class": "section-item-marquee-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h3", "label": "Small" },
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Row"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "row_height",
      "label": "Row height",
      "min": 60,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Image height",
      "min": 50,
      "max": 150,
      "step": 2,
      "unit": "px",
      "default": 72
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Scroll direction",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll speed (seconds per cycle)",
      "min": 10,
      "max": 120,
      "step": 5,
      "unit": "s",
      "default": 30
    },
    {
      "type": "range",
      "id": "image_gap",
      "label": "Space between images",
      "min": 20,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "text",
          "id": "item_name",
          "label": "Item name",
          "default": "Item"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Item marquee",
      "blocks": [
        { "type": "item", "settings": { "item_name": "Item 1" } },
        { "type": "item", "settings": { "item_name": "Item 2" } },
        { "type": "item", "settings": { "item_name": "Item 3" } },
        { "type": "item", "settings": { "item_name": "Item 4" } },
        { "type": "item", "settings": { "item_name": "Item 5" } }
      ]
    }
  ]
}
{% endschema %}