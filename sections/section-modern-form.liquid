      "default": "Parlons de votre projet"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Remplissez ce formulaire et nous vous répondrons dans les plus brefs délais.</p>"
    },
    {
      "type": "text",
      "id": "quote",
      "label": "Citation (optionnel)",
      "default": "« Votre message est important pour nous. »"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Note (optionnel)",
      "default": "Temps de réponse estimé : 24 à 48h ouvrées."
    },
    {
      "type": "header",
      "content": "Formulaire (Côté droit)"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Titre du formulaire",
      "default": "Formulaire de contact"
    },
    {
