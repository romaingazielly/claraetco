    },
    {
      "type": "text",
      "id": "city_placeholder",
      "label": "Placeholder Ville",
      "default": "Votre ville"
    },
    {
      "type": "text",
      "id": "country_label",
      "label": "Label Pays",
      "default": "Pays"
    },
    {
      "type": "text",
      "id": "country_placeholder",
      "label": "Placeholder Pays",
      "default": "Votre pays"
    },
    {
      "type": "header",
