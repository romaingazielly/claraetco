      "id": "success_message",
      "label": "Message de succès",
      "default": "Merci pour votre message. Nous vous répondrons dans les plus brefs délais."
    },
    {
      "type": "header",
      "content": "Champs du formulaire"
    },
    {
      "type": "text",
      "id": "firstname_label",
      "label": "Label Prénom",
      "default": "Prénom"
    },
    {
      "type": "text",
      "id": "firstname_placeholder",
      "label": "Placeholder Prénom",
      "default": "Votre prénom"
    },
    {
      "type": "checkbox",
      "id": "firstname_required",
      "label": "Prénom requis",
      "default": false
    },
    {
      "type": "text",
      "id": "lastname_label",
      "label": "Label Nom",
      "default": "Nom"
    },
    {
      "type": "text",
      "id": "lastname_placeholder",
      "label": "Placeholder Nom",
      "default": "Votre nom"
    },
    {
      "type": "checkbox",
      "id": "lastname_required",
      "label": "Nom requis",
      "default": false
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Label Email",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Placeholder Email",
      "default": "votre@email.com"
    },
    {
      "type": "header",
      "content": "Champ personnalisé 1"
    },
    {
      "type": "checkbox",
      "id": "show_custom_field_1",
      "label": "Afficher champ personnalisé 1",
      "default": false
    },
    {
      "type": "text",
      "id": "custom_field_1_label",
      "label": "Label",
      "default": "Nom de votre boutique"
    },
    {
      "type": "text",
      "id": "custom_field_1_placeholder",
      "label": "Placeholder",
      "default": "Nom de l'enseigne"
    },
    {
      "type": "checkbox",
      "id": "custom_field_1_required",
