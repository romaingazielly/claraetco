      "default": "#173557"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#111111"
    }
  ],
  "presets": [
    {
      "name": "Modern Form",
      "category": "Custom"
    }
  ]
